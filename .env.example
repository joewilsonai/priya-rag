# Copy to .env and fill in your OpenAI API key.
# Used at ingest time (one-time embedding of the corpus, ~$0.02) and at
# query time (one embedding per question, ~$0.0001 per query).
#
# To swap to a fully local embedding model with no API key needed,
# see the comment in src/embed.ts about @xenova/transformers.

OPENAI_API_KEY=sk-proj-your-key-here
